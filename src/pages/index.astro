---
import "../styles/global.css";
import Layout from "../layouts/layout.astro";
import { PERSONAL_INFO, SKILLS, PROJECTS, ACHIEVEMENTS } from "../consts";

const currentYear = new Date().getFullYear();
---

<Layout
	title={`${PERSONAL_INFO.name} | ${PERSONAL_INFO.role}`}
	description={PERSONAL_INFO.tagline}
>
	<main class="min-h-screen bg-white dark:bg-neutral-950 text-neutral-900 dark:text-neutral-100">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-24">
			
			<!-- Header/Hero -->
			<header class="mb-12 sm:mb-20">
				<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 tracking-tight">
					{PERSONAL_INFO.name}
				</h1>
				<p class="text-base sm:text-lg text-neutral-600 dark:text-neutral-400 mb-6">
					{PERSONAL_INFO.tagline}
				</p>
				<div class="flex flex-wrap gap-4 text-sm text-neutral-600 dark:text-neutral-400">
					<div class="flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
						{PERSONAL_INFO.location}
					</div>
					<div class="flex items-center gap-2">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-width="2"></rect><line x1="16" y1="2" x2="16" y2="6" stroke-width="2"></line><line x1="8" y1="2" x2="8" y2="6" stroke-width="2"></line><line x1="3" y1="10" x2="21" y2="10" stroke-width="2"></line></svg>
						Graduating 2026
					</div>
				</div>
				<div class="flex gap-4 mt-6">
					<a 
						href={PERSONAL_INFO.github}
						target="_blank"
						rel="noopener noreferrer"
						class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors"
						aria-label="GitHub"
					>
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
					<a 
						href={PERSONAL_INFO.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors"
						aria-label="LinkedIn"
					>
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					</a>
					<a 
						href={PERSONAL_INFO.x}
						target="_blank"
						rel="noopener noreferrer"
						class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors"
						aria-label="X"
					>
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2H21l-6.51 7.437L22.148 22h-5.995l-4.694-6.133L6.09 22H3.333l6.962-7.955L1.852 2h6.148l4.243 5.593L18.244 2Zm-.967 18.348h1.526L7.15 3.566H5.512l11.765 16.782Z"/></svg>
					</a>
					<a 
						href={`mailto:${PERSONAL_INFO.email}`}
						class="text-neutral-600 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100 transition-colors"
						aria-label="Email"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
					</a>
				</div>
			</header>

			<section class="mb-12 sm:mb-20">
				<h2 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6">About</h2>
				<div class="prose prose-neutral dark:prose-invert max-w-none">
					<p class="text-sm sm:text-base text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
						What got me into programming was how it felt like magic—building something from nothing, writing spells that affect reality. I've always been into fantasy, especially mages and spellcasting, and coding emulates that experience.
					</p>
					<p class="text-sm sm:text-base text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4">
						I'm finishing my BSIT at Mindoro State University - Bongabong Campus. For my capstone project, I saw government procurement drowning in manual processes and corruption. So I built ProcuChain—a blockchain system that's now used by actual Bids and Awards Committees. Solo project, real impact.
					</p>
					<p class="text-sm sm:text-base text-neutral-700 dark:text-neutral-300 leading-relaxed">
						I'm also into cybersecurity. Scored highest in my region for Hack4Gov 3 as an individual, earned a wildcard to nationals. When I'm not coding, I'm reading manhwa or manga in <a href="https://github.com/mihonapp/mihon" target="_blank" rel="noopener noreferrer" class="underline hover:text-neutral-900 dark:hover:text-neutral-100">Mihon</a> (which I contribute to), breaking things in CTF challenges, or tinkering with AI.
					</p>
				</div>
			</section>

			<!-- Projects -->
			<section class="mb-12 sm:mb-20">
				<h2 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6">Selected Work</h2>
				<div class="space-y-6 sm:space-y-8">
					{PROJECTS.map((project) => (
						<div class="group">
							<div class="flex items-start justify-between gap-4 mb-2">
								<h3 class="text-base sm:text-lg font-medium text-neutral-900 dark:text-neutral-100">
									{project.title}
								</h3>
								<div class="flex gap-2 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity">
									{project.link && (
										<a
											href={project.link}
											target="_blank"
											rel="noopener noreferrer"
											class="text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100"
											aria-label="Visit project"
										>
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
										</a>
									)}
									<a
										href={project.github}
										target="_blank"
										rel="noopener noreferrer"
										class="text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100"
										aria-label="View source"
									>
										<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
									</a>
								</div>
							</div>
							<p class="text-neutral-600 dark:text-neutral-400 text-sm mb-3">
								{project.description}
							</p>
							<div class="flex flex-wrap gap-2">
								{project.tech.slice(0, 4).map((tech) => (
									<span class="text-xs text-neutral-500 dark:text-neutral-500">
										{tech}
									</span>
								))}
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Experience/Achievements -->
			<section class="mb-12 sm:mb-20">
				<h2 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6">Recognition</h2>
				<div class="space-y-4">
					{ACHIEVEMENTS.map((achievement) => (
						<div>
							<div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4 mb-1">
								<h3 class="text-sm sm:text-base font-medium text-neutral-900 dark:text-neutral-100">
									{achievement.title}
								</h3>
								<span class="text-sm text-neutral-500 dark:text-neutral-500">
									{achievement.date}
								</span>
							</div>
							<p class="text-sm text-neutral-600 dark:text-neutral-400">
								{achievement.description}
							</p>
						</div>
					))}
				</div>
			</section>

			<!-- Skills -->
			<section class="mb-12 sm:mb-20">
				<h2 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6">Skills</h2>
				<div class="flex flex-wrap gap-2">
					{SKILLS.map((skill) => (
						<span class="text-sm text-neutral-600 dark:text-neutral-400">
							{skill}
						</span>
					))}
				</div>
			</section>

			<!-- Contact -->
			<section class="mb-8 sm:mb-12">
				<h2 class="text-xl sm:text-2xl font-semibold mb-4 sm:mb-6">Get in Touch</h2>
				<p class="text-sm sm:text-base text-neutral-600 dark:text-neutral-400 mb-4">
					I'm currently looking for new opportunities. Feel free to reach out if you'd like to work together.
				</p>
				<a 
					href={`mailto:${PERSONAL_INFO.email}`}
					class="inline-flex items-center gap-2 text-neutral-900 dark:text-neutral-100 hover:text-neutral-600 dark:hover:text-neutral-400 transition-colors"
				>
					<svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
					{PERSONAL_INFO.email}
				</a>
			</section>

			<!-- Footer -->
			<footer class="pt-8 border-t border-neutral-200 dark:border-neutral-800">
				<p class="text-xs text-neutral-500 dark:text-neutral-500 text-center">
					© {currentYear} {PERSONAL_INFO.name}
				</p>
			</footer>

		</div>
	</main>
</Layout>
