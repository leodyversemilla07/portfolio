---
import "../styles/global.css";
import Layout from "../layouts/layout.astro";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import { SupportFormIsland } from "../components/support-form-island.tsx";
import { ErrorBoundary } from "../components/error-boundary.tsx";
import { PERSONAL_INFO } from "../consts";
import { Coffee, Heart, CreditCard, Smartphone } from "lucide-react";
---

<Layout
    title={`Support ${PERSONAL_INFO.name} | Buy Me a Coffee`}
    description={`Support ${PERSONAL_INFO.name}'s work by buying a coffee. Your support helps keep the projects going!`}
>
    <main
        class="min-h-screen bg-neutral-50 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 transition-colors duration-300 font-sans selection:bg-emerald-200 dark:selection:bg-emerald-900"
    >
        <Header />
        <div class="max-w-3xl mx-auto px-6 pt-32 pb-20">
            <!-- Hero -->
            <div class="text-center mb-12">
                <div
                    class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 dark:bg-emerald-900/30 mb-6"
                >
                    <Coffee
                        size={40}
                        className="text-emerald-600 dark:text-emerald-400"
                    />
                </div>
                <h1
                    class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4"
                >
                    Buy Me a <span
                        class="text-emerald-600 dark:text-emerald-400"
                        >Coffee</span
                    >
                </h1>
                <p
                    class="text-lg text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto leading-relaxed"
                >
                    If you enjoy my work or find my projects helpful, consider
                    supporting me with a coffee! Your support helps me continue
                    building and maintaining open-source projects.
                </p>
            </div>

            <!-- Support Form -->
            <div
                class="bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 sm:p-8 mb-8 shadow-sm"
            >
                <SupportFormIsland client:visible />
            </div>

            <!-- Payment Methods -->
            <div class="text-center">
                <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4">
                    Secure payments powered by PayMongo
                </p>
                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <div
                        class="flex items-center gap-2 px-3 py-2 bg-neutral-100 dark:bg-neutral-800 rounded-lg text-sm text-neutral-600 dark:text-neutral-300"
                    >
                        <Smartphone size={16} />
                        <span>GCash</span>
                    </div>
                    <div
                        class="flex items-center gap-2 px-3 py-2 bg-neutral-100 dark:bg-neutral-800 rounded-lg text-sm text-neutral-600 dark:text-neutral-300"
                    >
                        <Smartphone size={16} />
                        <span>Maya</span>
                    </div>
                    <div
                        class="flex items-center gap-2 px-3 py-2 bg-neutral-100 dark:bg-neutral-800 rounded-lg text-sm text-neutral-600 dark:text-neutral-300"
                    >
                        <Smartphone size={16} />
                        <span>GrabPay</span>
                    </div>
                    <div
                        class="flex items-center gap-2 px-3 py-2 bg-neutral-100 dark:bg-neutral-800 rounded-lg text-sm text-neutral-600 dark:text-neutral-300"
                    >
                        <CreditCard size={16} />
                        <span>Card</span>
                    </div>
                </div>
            </div>

            <!-- Thank You Note -->
            <div class="mt-12 text-center">
                <div
                    class="inline-flex items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400"
                >
                    <Heart size={14} className="text-red-500" />
                    <span>Thank you for your support!</span>
                </div>
            </div>
        </div>
        <Footer />
    </main>
</Layout>
