---
import "../styles/global.css";
import Layout from "../layouts/layout.astro";
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";
import { ContactFormIsland } from "../components/contact-form-island.tsx";
import { ErrorBoundary } from "../components/error-boundary.tsx";
import { PERSONAL_INFO } from "../consts";
import { Mail } from "lucide-react";

const WEB3FORMS_ACCESS_KEY =
    import.meta.env.WEB3FORMS_ACCESS_KEY ||
    "5a398329-3ae0-4a3a-85eb-5d335db64dc5";
---

<Layout
    title={`Contact ${PERSONAL_INFO.name}`}
    description={`Get in touch with ${PERSONAL_INFO.name}. Open to new opportunities and collaborations.`}
>
    <main
        class="min-h-screen bg-neutral-50 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 transition-colors duration-300 font-sans selection:bg-emerald-200 dark:selection:bg-emerald-900"
    >
        <Header />
        <div class="max-w-3xl mx-auto px-6 pt-32 pb-20">
            <!-- Hero -->
            <div class="text-center mb-12">
                <div
                    class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 dark:bg-emerald-900/30 mb-6"
                >
                    <Mail
                        size={40}
                        className="text-emerald-600 dark:text-emerald-400"
                    />
                </div>
                <h1
                    class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4"
                >
                    Get in <span class="text-emerald-600 dark:text-emerald-400"
                        >Touch</span
                    >
                </h1>
                <p
                    class="text-lg text-neutral-600 dark:text-neutral-400 max-w-xl mx-auto leading-relaxed"
                >
                    I'm currently open to new opportunities. Feel free to reach
                    out if you have a question or just want to connect.
                </p>
            </div>

            <!-- Contact Form -->
            <div
                class="bg-white dark:bg-neutral-800 rounded-xl border border-neutral-200 dark:border-neutral-700 p-6 sm:p-8 shadow-sm"
            >
                <ContactFormIsland client:visible accessKey={WEB3FORMS_ACCESS_KEY} />
            </div>
        </div>
        <Footer />
    </main>
</Layout>
