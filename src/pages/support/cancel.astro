---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { PERSONAL_INFO } from "../../consts";
import { XCircle, Coffee, ArrowLeft, RefreshCw } from "lucide-react";
---

<Layout
    title={`Payment Cancelled | ${PERSONAL_INFO.name}`}
    description="Payment was cancelled"
>
    <main
        class="min-h-screen bg-neutral-50 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 transition-colors duration-300 font-sans selection:bg-emerald-200 dark:selection:bg-emerald-900"
    >
        <Header />
        <div class="max-w-2xl mx-auto px-6 pt-32 pb-20 text-center">
            <!-- Cancel Icon -->
            <div
                class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-neutral-100 dark:bg-neutral-800 mb-8 animate-in zoom-in duration-500"
            >
                <XCircle size={48} className="text-neutral-400" />
            </div>

            <!-- Message -->
            <h1
                class="text-3xl sm:text-4xl font-bold tracking-tight mb-4 animate-in slide-in-from-bottom-4 fade-in duration-700"
            >
                Payment Cancelled
            </h1>
            <p
                class="text-lg text-neutral-600 dark:text-neutral-400 max-w-md mx-auto leading-relaxed mb-8 animate-in slide-in-from-bottom-6 fade-in duration-700 delay-150"
            >
                No worries! Your payment was not processed. You can try again
                anytime or just continue exploring.
            </p>

            <!-- Actions -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-in slide-in-from-bottom-8 fade-in duration-700 delay-300"
            >
                <a
                    href="/support"
                    class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-lg transition-all"
                >
                    <RefreshCw size={18} />
                    Try Again
                </a>
                <a
                    href="/"
                    class="inline-flex items-center gap-2 px-6 py-3 border border-neutral-300 dark:border-neutral-700 text-neutral-700 dark:text-neutral-300 font-medium rounded-lg hover:border-neutral-900 dark:hover:border-neutral-100 transition-all"
                >
                    <ArrowLeft size={18} />
                    Back to Home
                </a>
            </div>

            <!-- Friendly Note -->
            <div
                class="mt-12 flex items-center justify-center gap-2 text-sm text-neutral-500 dark:text-neutral-400"
            >
                <Coffee size={16} />
                <span>I appreciate you considering to support!</span>
            </div>
        </div>
        <Footer />
    </main>
</Layout>
