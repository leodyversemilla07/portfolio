---
import "../../styles/global.css";
import Layout from "../../layouts/layout.astro";
import Header from "../../components/header.astro";
import Footer from "../../components/footer.astro";
import { PERSONAL_INFO } from "../../consts";
import { CheckCircle, Heart, ArrowLeft, Coffee } from "lucide-react";
---

<Layout
    title={`Thank You! | ${PERSONAL_INFO.name}`}
    description="Thank you for your support!"
>
    <main
        class="min-h-screen bg-neutral-50 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 transition-colors duration-300 font-sans selection:bg-emerald-200 dark:selection:bg-emerald-900"
    >
        <Header />
        <div class="max-w-2xl mx-auto px-6 pt-32 pb-20 text-center">
            <!-- Success Icon -->
            <div class="relative inline-block mb-8">
                <div
                    class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-emerald-100 dark:bg-emerald-900/30 animate-in zoom-in duration-500"
                >
                    <CheckCircle
                        size={48}
                        className="text-emerald-600 dark:text-emerald-400"
                    />
                </div>
                <div class="absolute -top-2 -right-2 animate-bounce">
                    <Coffee
                        size={24}
                        className="text-emerald-600 dark:text-emerald-400"
                    />
                </div>
            </div>

            <!-- Thank You Message -->
            <h1
                class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-4 animate-in slide-in-from-bottom-4 fade-in duration-700"
            >
                Thank You!
            </h1>
            <p
                class="text-lg text-neutral-600 dark:text-neutral-400 max-w-md mx-auto leading-relaxed mb-8 animate-in slide-in-from-bottom-6 fade-in duration-700 delay-150"
            >
                Your support means the world to me! It helps me continue
                building and maintaining projects that (hopefully) make a
                difference.
            </p>

            <!-- Heart Animation -->
            <div
                class="flex items-center justify-center gap-1 mb-10 animate-in fade-in duration-1000 delay-300"
            >
                {
                    [...Array(5)].map((_, i) => (
                        <Heart
                            size={20}
                            className="text-red-500 fill-red-500"
                            style={{ animationDelay: `${i * 100}ms` }}
                        />
                    ))
                }
            </div>

            <!-- Back to Home -->
            <a
                href="/"
                class="inline-flex items-center gap-2 px-6 py-3 bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 font-medium rounded-lg hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-all animate-in slide-in-from-bottom-8 fade-in duration-700 delay-500"
            >
                <ArrowLeft size={18} />
                Back to Home
            </a>
        </div>
        <Footer />
    </main>
</Layout>
