---
import { ModeToggle } from "./ModeToggle.tsx";
import { MobileMenu } from "./MobileMenu.tsx";
import { Terminal } from "lucide-react";
import { PERSONAL_INFO } from "../consts";

const navItems = [
  { label: "Home", href: "/" },
  { label: "Contact", href: "/contact" },
  { label: "Support", href: "/support" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};

import { cn } from "../lib/utils";
---

<nav
  class="fixed top-0 w-full z-50 bg-neutral-50/90 dark:bg-neutral-900/90 backdrop-blur-sm border-b border-neutral-200 dark:border-neutral-800"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 h-14 sm:h-16 flex items-center justify-between"
  >
    <a
      href="/"
      class="font-bold text-sm sm:text-lg tracking-tight flex items-center gap-2 hover:opacity-80 transition-opacity"
    >
      <Terminal
        client:load
        className="size-4 sm:size-5 text-emerald-600 dark:text-emerald-400"
      />
      <span class="truncate max-w-[120px] sm:max-w-none"
        >{PERSONAL_INFO.name}</span
      >
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      {/* Desktop Nav */}
      <div
        class="hidden sm:flex gap-4 lg:gap-6 text-xs lg:text-sm font-medium text-neutral-500 dark:text-neutral-400"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class={cn(
                "capitalize transition-colors",
                isActive(item.href)
                  ? "text-emerald-600 dark:text-emerald-400 font-semibold"
                  : "hover:text-neutral-900 dark:hover:text-neutral-100",
              )}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-1 sm:gap-2">
        <ModeToggle client:load />
        {/* Mobile Nav */}
        <MobileMenu items={navItems} currentPath={pathname} client:load />
      </div>
    </div>
  </div>
</nav>
