---
import Section from '../Section.astro';
import { SKILLS } from '../../consts';
---

<Section title="Tech Stack" id="skills">
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-y-3 gap-x-4 sm:gap-x-8">
    {SKILLS.map((skill) => (
      <div class="flex items-center gap-2 sm:gap-3 text-sm sm:text-base text-neutral-700 dark:text-neutral-300">
        <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full shrink-0" />
        <span class="truncate">{skill}</span>
      </div>
    ))}
  </div>
</Section>