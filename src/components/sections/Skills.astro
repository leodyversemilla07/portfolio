---
import Section from '../Section.astro';
import { SKILLS } from '../../consts';
---

<Section title="Tech Stack" id="skills">
  <div class="grid grid-cols-2 md:grid-cols-3 gap-y-4 gap-x-8">
    {SKILLS.map((skill) => (
      <div class="flex items-center gap-3 text-neutral-700 dark:text-neutral-300">
        <div class="w-1.5 h-1.5 bg-emerald-500 rounded-full" />
        {skill}
      </div>
    ))}
  </div>
</Section>