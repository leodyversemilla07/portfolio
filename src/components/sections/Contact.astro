---
import { Mail } from 'lucide-react';
import Section from '../Section.astro';
import { PERSONAL_INFO } from '../../consts';
---

<Section title="Contact" id="contact">
  <p class="text-xl sm:text-2xl md:text-3xl font-medium text-neutral-900 dark:text-neutral-100 mb-4 sm:mb-6">
    Interested in working together?
  </p>
  <p class="text-neutral-600 dark:text-neutral-400 mb-6 sm:mb-8 max-w-xl text-sm sm:text-base">
    I'm currently open to new opportunities. Feel free to reach out if you have a question or just want to connect.
  </p>
  <a
    href={`mailto:${PERSONAL_INFO.email}`}
    class="inline-flex items-center gap-2 text-base sm:text-lg md:text-xl font-medium text-emerald-600 dark:text-emerald-400 hover:underline underline-offset-4"
  >
    <Mail size={20} />
    <span class="break-all">{PERSONAL_INFO.email}</span>
  </a>
</Section>