---
import Section from '../section.astro';
import { Trophy, Award, GraduationCap } from 'lucide-react';
import { ACHIEVEMENTS } from '../../consts';

const iconMap = {
  competition: Trophy,
  scholarship: Award,
  academic: GraduationCap
};

const badgeColors = {
  competition: "bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-300",
  scholarship: "bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800 text-blue-700 dark:text-blue-300",
  academic: "bg-emerald-50 dark:bg-emerald-900/20 border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-300"
};
---

<Section title="Achievements" id="achievements">
  <div class="grid gap-3 sm:grid-cols-2">
    {ACHIEVEMENTS.map((achievement) => {
      const Icon = iconMap[achievement.type as keyof typeof iconMap];
      return (
        <div class="group flex items-start gap-3 p-3 sm:p-4 bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 hover:border-emerald-300 dark:hover:border-emerald-700 transition-all duration-200">
          <div class={`p-2 rounded-lg border shrink-0 ${badgeColors[achievement.type as keyof typeof badgeColors]}`}>
            <Icon size={18} />
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2 mb-0.5 sm:mb-1">
              <span class="text-xs font-medium uppercase tracking-wider text-neutral-500 dark:text-neutral-400 truncate">
                {achievement.type}
              </span>
              <span class="text-xs text-neutral-400 dark:text-neutral-500 shrink-0">
                {achievement.date}
              </span>
            </div>
            <h3 class="text-sm sm:text-base font-semibold text-neutral-900 dark:text-neutral-100 mb-0.5 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">
              {achievement.title}
            </h3>
            <p class="text-xs sm:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
              {achievement.description}
            </p>
          </div>
        </div>
      );
    })}
  </div>
</Section>