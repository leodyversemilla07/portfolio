---
import { ArrowRight, Download } from 'lucide-react';
import { PERSONAL_INFO } from '../../consts';
---

<div class="relative min-h-[60vh] flex flex-col justify-center mb-12 isolate">
  
  {/* Background Glow */}
  <div 
    class="absolute -z-10 top-[-20%] left-[-10%] w-[40%] h-[60%] rounded-full bg-emerald-400/10 dark:bg-emerald-500/10 blur-3xl animate-in fade-in duration-1000"
  />

  {/* Status Badge */}
  <div class="animate-in slide-in-from-bottom-4 fade-in duration-700 mb-6 sm:mb-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-100 dark:border-emerald-800 text-xs font-medium text-emerald-700 dark:text-emerald-300">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      Available for opportunities
    </div>
  </div>

  <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tighter mb-4 sm:mb-6 leading-tight animate-in slide-in-from-bottom-6 fade-in duration-700 delay-150">
    I build robust <br />
    <span class="text-emerald-600 dark:text-emerald-400">software solutions.</span>
  </h1>
  <p class="text-lg sm:text-xl text-neutral-600 dark:text-neutral-400 max-w-2xl leading-relaxed mb-6 sm:mb-8 animate-in slide-in-from-bottom-8 fade-in duration-700 delay-300">
    {PERSONAL_INFO.tagline}
  </p>

  <div class="flex flex-wrap gap-3 sm:gap-4 animate-in slide-in-from-bottom-10 fade-in duration-700 delay-500">
    <a
      href="#contact"
      class="flex items-center gap-2 px-5 py-2.5 sm:px-6 sm:py-3 bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 font-medium rounded-md hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-all text-sm sm:text-base"
    >
      Contact Me <ArrowRight size={18} />
    </a>
    <a
      href={PERSONAL_INFO.resumeLink}
      class="flex items-center gap-2 px-5 py-2.5 sm:px-6 sm:py-3 border border-neutral-300 dark:border-neutral-700 font-medium rounded-md hover:border-neutral-900 dark:hover:border-neutral-100 transition-all text-sm sm:text-base"
    >
      Resume <Download size={18} />
    </a>
  </div>
</div>